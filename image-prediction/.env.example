# Which backend to use: "openai" or "gemini"
PROVIDER=openai

# OpenAI (used when PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Only for reasoning models (e.g. o-series, gpt-5). Leave unset otherwise.
# REASONING_EFFORT=high

# Gemini (used when PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Thinking budget in tokens. Leave unset for model default.
#   0  = disable thinking (Flash only; Pro cannot disable)
#   -1 = dynamic (model decides)
#   N  = cap at N tokens (e.g. Pro: 128-32768, Flash: 0-24576)
# GEMINI_THINKING_BUDGET=-1
# Media resolution per image: low (~64 tok), medium (~256 tok), high (~256 tok zoomed).
# Leave unset for model default (HIGH on 2.5 Pro).
# GEMINI_MEDIA_RESOLUTION=high

# External finger-word detector (MediaPipe + EasyOCR, runs via `uv run`).
# Optional — disabled by default. Set to "true" to enable per-request augmentation
# with candidate words pointed at by the index finger.
FINGER_DETECTOR_ENABLED=false
FINGER_DETECTOR_PATH=/Users/christoph/Development/Projects/codex-hack/finger-word-detector
FINGER_DETECTOR_TOP_N=5
FINGER_DETECTOR_TIMEOUT=60
